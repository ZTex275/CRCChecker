<Window
    x:Class="CRCChecker.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:CRCChecker"
    Title="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=WindowTitle}"
    Width="600"
    Height="450"
    MinWidth="500"
    MinHeight="400"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="5" />
            <Setter Property="Padding" Value="10,5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#FF4A90E2" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF357ABD" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TextStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="5" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#FF2C3E50" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,10,0,10" />
        </Style>

        <Style x:Key="LanguageButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#FF6C757D" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF5A6268" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActiveLanguageButtonStyle" TargetType="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Background" Value="#FF007ACC" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF0056B3" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Title  -->
        <TextBlock
            Grid.Row="0"
            Style="{StaticResource HeaderStyle}"
            Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=TitleText}" />

        <!--  Language Selection  -->
        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,10"
            HorizontalAlignment="Center"
            Orientation="Horizontal">
            <Button
                x:Name="RussianButton"
                Width="50"
                Height="40"
                Click="RussianButton_Click"
                Content="RU"
                Style="{StaticResource LanguageButtonStyle}" />
            <Button
                x:Name="EnglishButton"
                Width="50"
                Height="40"
                Click="EnglishButton_Click"
                Content="EN"
                Style="{StaticResource LanguageButtonStyle}" />
        </StackPanel>

        <!--  File Selection  -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="FilePathTextBox"
                Grid.Column="0"
                Margin="5"
                Padding="10"
                FontSize="14"
                IsReadOnly="True"
                Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=NoFileSelected, Mode=OneWay}" />

            <Button
                x:Name="BrowseButton"
                Grid.Column="1"
                Click="BrowseButton_Click"
                Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=BrowseButton}"
                Style="{StaticResource ButtonStyle}" />
        </Grid>

        <!--  Separator  -->
        <Separator Grid.Row="3" Margin="0,10,0,10" />

        <!--  Results Section  -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="150" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                FontWeight="Bold"
                Style="{StaticResource TextStyle}"
                Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=FileNameLabel}" />
            <TextBlock
                x:Name="FileNameText"
                Grid.Row="0"
                Grid.Column="1"
                Style="{StaticResource TextStyle}"
                Text="-" />

            <TextBlock
                Grid.Row="1"
                Grid.Column="0"
                FontWeight="Bold"
                Style="{StaticResource TextStyle}"
                Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=FileSizeLabel}" />
            <TextBlock
                x:Name="FileSizeText"
                Grid.Row="1"
                Grid.Column="1"
                Style="{StaticResource TextStyle}"
                Text="-" />

            <TextBlock
                Grid.Row="2"
                Grid.Column="0"
                FontWeight="Bold"
                Style="{StaticResource TextStyle}"
                Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=LastModifiedLabel}" />
            <TextBlock
                x:Name="LastModifiedText"
                Grid.Row="2"
                Grid.Column="1"
                Style="{StaticResource TextStyle}"
                Text="-" />

            <TextBlock
                Grid.Row="3"
                Grid.Column="0"
                FontWeight="Bold"
                Style="{StaticResource TextStyle}"
                Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=CRC32Label}" />
            <TextBlock
                x:Name="CRC32Text"
                Grid.Row="3"
                Grid.Column="1"
                FontFamily="Consolas"
                Style="{StaticResource TextStyle}"
                Text="-" />
        </Grid>
    </Grid>
</Window>
